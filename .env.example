# Saltspire MUD -- environment configuration example
# Copy to .env and adjust values before running.

# --- Ollama NPC AI ---
# URL of the Ollama server. When running in Docker Compose this is typically
# the service name (e.g. "ollama") on the shared network.
OLLAMA_URL=http://ollama:11434

# Model tag to use. Must already be pulled on the Ollama server:
#   docker exec -it <ollama-container> ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b

# Seconds to wait for Ollama before giving up and using pre-scripted fallback.
OLLAMA_TIMEOUT=8
